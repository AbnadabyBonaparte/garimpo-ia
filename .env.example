# ═══════════════════════════════════════════
# GARIMPO IA™ — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini AI
VITE_GEMINI_API_KEY=your-gemini-api-key

# Stripe
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
# URL of create-checkout-session Edge Function (e.g. https://<project>.supabase.co/functions/v1/create-checkout-session)
VITE_STRIPE_CHECKOUT_API_URL=

# App
VITE_APP_URL=http://localhost:5173
