# ═══════════════════════════════════════════
# GARIMPO IA™ — Variáveis de Ambiente
# ═══════════════════════════════════════════
# Copie para .env.local e preencha os valores.
# NUNCA commite .env.local no git.

# ── Supabase ──
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ── Stripe ──
# Chave pública (pk_*) — a chave secreta fica APENAS na Edge Function
VITE_STRIPE_PUBLIC_KEY=pk_test_sua-chave-aqui

# ── Edge Functions (Supabase) ──
# Formato: {SUPABASE_URL}/functions/v1/{nome-da-function}
# GEMINI_API_KEY é segredo server-side na Edge Function — NÃO expor aqui
VITE_RUN_AI_ANALYSIS_API_URL=https://seu-projeto.supabase.co/functions/v1/run-ai-analysis
VITE_STRIPE_CHECKOUT_API_URL=https://seu-projeto.supabase.co/functions/v1/create-checkout-session

# ── App ──
VITE_APP_URL=http://localhost:5173
