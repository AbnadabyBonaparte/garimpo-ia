# ═══════════════════════════════════════════
# GARIMPO IA™ — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (public key only — secret key lives in Edge Functions)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
# URL of create-checkout-session Edge Function
VITE_STRIPE_CHECKOUT_API_URL=

# URL of run-ai-analysis Edge Function
# GEMINI_API_KEY is a server-side secret in the Edge Function — NOT exposed here
VITE_RUN_AI_ANALYSIS_API_URL=

# App
VITE_APP_URL=http://localhost:5173
